APP_NAME=Audiobook Editor API
APP_ENV=development
DATABASE_URL=sqlite:///./audiobook_editor.db
DATA_ROOT=../../data/projects
CORS_ORIGINS=http://localhost:5173
WHISPERX_MODEL=
WHISPERX_FALLBACK_MODEL=tiny
# GPU auto-detection: set to "auto" (recommended), "cuda", or "cpu"
WHISPERX_DEVICE=auto
# Compute type: leave blank for auto-detect, or set to float16/int8_float16/int8
WHISPERX_COMPUTE_TYPE=
WHISPERX_PROFILE=balanced
WHISPERX_CPU_THREADS=
WHISPERX_NUM_WORKERS=

# --- API Keys (optional) ---
# OpenAI API key — enables Whisper API transcription and GPT issue triage
OPENAI_API_KEY=
# Anthropic API key — enables Claude issue triage
ANTHROPIC_API_KEY=
# LLM provider for issue triage: "openai", "anthropic", or blank to disable
LLM_PROVIDER=
# Transcription backend: "local" (default, uses faster-whisper) or "whisper_api" (uses OpenAI Whisper API)
TRANSCRIPTION_BACKEND=local
