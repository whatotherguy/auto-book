                                                                                                   \
      \cf7 def\cf9  inject_click(self, y: np.ndarray, sr: \cf8 int\cf9 , position_ms: \cf8 int\cf9 ,\cf2                              \
  \cf9                      amplitude: \cf8 float\cf9  = \cf4 0.8\cf9 ) -> np.ndarray:\cf2 \
