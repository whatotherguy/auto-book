                                                                                                   \
  \cf4 # File: services/scoring/features.py\cf2                                                              \
                                                                                                   \
  \cf6 @dataclass\cf2 \
  \cf7 class RawFeatureCatalog:\cf2                                                                          \
      \cf5 """Complete inventory of raw features available per segment/issue."""\cf2                         \
                                                                                                   \
      \cf4 # === TRANSCRIPT / ALIGNMENT ===\cf2                                                              \
      alignment_op: \cf8 str\cf2                \cf4 # "equal", "replace", "insert", "delete"\cf2                      \
      match_ratio: \cf8 float\cf2               \cf4 # chapter-level alignment quality (0-1)\cf2                       \
      expected_text: \cf8 str\cf2               \cf4 # manuscript text\cf2                                             \
      spoken_text: \cf8 str\cf2                 \cf4 # transcribed text\cf2                                            \
      word_count_expected: \cf8 int\cf2         \cf4 # len(expected_text.split())\cf2                                  \
      word_count_spoken: \cf8 int\cf2           \cf4 # len(spoken_text.split())\cf2                                    \
      whisper_word_confidence: \cf8 float\cf2   \cf4 # mean Whisper confidence for segment tokens\cf2                  \
                                                                                                   \
      \cf4 # === TIMING ===\cf2                                                                              \
      start_ms: \cf8 int\cf2                                                                                 \
      end_ms: \cf8 int\cf2                                                                                   \
      duration_ms: \cf8 int\cf2                 \cf4 # end_ms - start_ms\cf2 \
      pause_before_ms: \cf8 int\cf2             \cf4 # gap from previous segment end\cf2                               \
      pause_after_ms: \cf8 int\cf2              \cf4 # gap to next segment start\cf2                                   \
  \
      \cf4 # === SIGNAL / DSP ===\cf2                                                                        \
      rms_db: \cf8 float\cf2                    \cf4 # segment RMS in dBFS\cf2 \
      spectral_centroid_hz: \cf8 float\cf2      \cf4 # frequency center of mass\cf2                                    \
      zero_crossing_rate: \cf8 float\cf2        \cf4 # ZCR (noisiness indicator)\cf2                                   \
      onset_strength: \cf8 float\cf2            \cf4 # onset detection strength\cf2                                    \
      crest_factor_db: \cf8 float\cf2           \cf4 # peak/RMS ratio \'97 transient indicator\cf2                        \
      bandwidth_hz: \cf8 float\cf2              \cf4 # spectral bandwidth\cf2                                          \
                                                                                                   \
      \cf4 # === PROSODY ===\cf2                                                                             \
      speech_rate_wps: \cf8 float\cf2           \cf4 # words per second\cf2 \
      f0_mean_hz: \cf8 float\cf2  | \cf7 None\cf2         \cf4 # fundamental frequency (pitch)\cf2                               \
      f0_std_hz: \cf8 float\cf2  | \cf7 None\cf2          \cf4 # pitch variation\cf2                                             \
      energy_contour: \cf8 list\cf2 [\cf8 float\cf2 ]     \cf4 # per-frame RMS\cf2                                               \
      f0_contour: \cf8 list\cf2 [\cf8 float\cf2 ]         \cf4 # per-frame F0\cf2                                                \
                                                                                                   \
      \cf4 # === VAD ===\cf2                                                                                 \
      vad_speech_ratio: \cf8 float\cf2          \cf4 # fraction of segment that is speech\cf2                          \
      vad_gap_count: \cf8 int\cf2               \cf4 # number of VAD silence gaps within segment\cf2                   \
      vad_longest_gap_ms: \cf8 int\cf2          \cf4 # longest internal silence\cf2                                    \
                                                                                                   \
      \cf4 # === CONTEXT ===\cf2                                                                             \
      position_in_chapter: \cf8 float\cf2       \cf4 # 0.0 = start, 1.0 = end\cf2                                      \
      is_first_sentence: \cf8 bool\cf2                                                                       \
      is_last_sentence: \cf8 bool\cf2                                                                        \
      at_paragraph_boundary: \cf8 bool\cf2                                                                   \
      manuscript_token_index: \cf8 int\cf2      \cf4 # position in manuscript\cf2                                      \
                                                                                                   \
  
\f2\b 1B. Derived Features (Layer 2)
\f1\b0 \
                                                                                                   \
  Computed from raw features using chapter-level baselines. These are the features primitive       \
  detectors consume.\
                                                                                                   \
  \cf4 # File: services/scoring/derived_features.py\cf2 \
                                                                                                   \
  \cf6 @dataclass\cf2 \
  \cf7 class DerivedFeatures:\cf2                                                                            \
      \cf5 """\cf2          \
  \cf5     All derived features are relative to an adaptive baseline.\cf2 \
  \cf5     They are z-scores, ratios, or deltas \'97 never absolute values.\cf2                                 \
  \cf5     """\cf2 \
                                                                                                   \
      \cf4 # === Z-SCORE NORMALIZED (relative to chapter/session baseline) ===\cf2                           \
      z_speech_rate: \cf8 float\cf2            \cf4 # (rate - mean) / std \'97 positive = fast\cf2 \
      z_f0: \cf8 float\cf2                     \cf4 # pitch deviation from narrator mean\cf2                           \
      z_energy: \cf8 float\cf2                 \cf4 # energy deviation from narrator mean\cf2 \
      z_pause_before: \cf8 float\cf2           \cf4 # pause length deviation\cf2                                       \
      z_pause_after: \cf8 float\cf2            \cf4 # pause length deviation\cf2                                       \
      z_duration: \cf8 float\cf2               \cf4 # segment duration deviation\cf2 \
      z_spectral_centroid: \cf8 float\cf2      \cf4 # tonal deviation\cf2                                              \
                                                                                                   \
      \cf4 # === RATIOS ===\cf2 \
      word_count_ratio: \cf8 float\cf2         \cf4 # spoken / expected \'97 1.0 = perfect\cf2                            \
      duration_ratio: \cf8 float\cf2           \cf4 # actual_ms / expected_ms_from_baseline\cf2                        \
      energy_variance_ratio: \cf8 float\cf2    \cf4 # segment energy variance / chapter mean variance\cf2              \
                                                                                                   \
      \cf4 # === DELTAS (vs. neighboring segments) ===\cf2                                                   \
      delta_energy_prev: \cf8 float\cf2        \cf4 # RMS change from previous segment (dB)\cf2                        \
      delta_energy_next: \cf8 float\cf2        \cf4 # RMS change to next segment (dB)\cf2                              \
      delta_f0_prev: \cf8 float\cf2            \cf4 # pitch change from previous segment (Hz)\cf2                      \
      delta_f0_next: \cf8 float\cf2            \cf4 # pitch change to next segment (Hz)\cf2                            \
      delta_rate_prev: \cf8 float\cf2          \cf4 # speech rate change from previous\cf2                             \
      delta_rate_next: \cf8 float\cf2          \cf4 # speech rate change to next\cf2                                   \
                  \
      \cf4 # === TEXT SIMILARITY ===\cf2                                                                     \
      levenshtein_distance: \cf8 int\cf2       \cf4 # edit distance between expected and spoken\cf2 \
      levenshtein_ratio: \cf8 float\cf2        \cf4 # normalized: 1.0 = identical\cf2                                  \
      token_overlap_ratio: \cf8 float\cf2      \cf4 # Jaccard overlap of word sets\cf2                                 \
      has_shared_prefix: \cf8 bool\cf2         \cf4 # spoken starts with same words as expected\cf2                    \
      shared_prefix_length: \cf8 int\cf2       \cf4 # how many leading words match\cf2                                 \
                                                                                                   \
      \cf4 # === COMPOSITE RAW ===\cf2                                                                       \
      silence_fraction: \cf8 float\cf2         \cf4 # (pause_before + pause_after) / duration\cf2 \
      is_isolated_speech: \cf8 bool\cf2        \cf4 # long pauses on both sides\cf2                                    \
                                                                                                   \
                                                                                                   \
  \cf7 def\cf9  compute_derived_features(\cf2                                                                     \
  \cf9     raw: RawFeatureCatalog,\cf2                                                                       \
  \cf9     baseline: \cf5 "AdaptiveBaseline"\cf9 ,\cf2 \
  \cf9     neighbors: \cf5 "NeighborContext"\cf9 ,\cf2 \
  \cf9 ) -> DerivedFeatures:\cf2                                                                             \
      \cf5 """Pure function: raw features + baseline \uc0\u8594  derived features."""\cf2 \
      \cf7 return\cf2  DerivedFeatures(                                                                      \
          z_speech_rate=baseline.z_score(\cf5 "speech_rate"\cf2 , raw.speech_rate_wps),                      \
          z_f0=baseline.z_score(\cf5 "f0_mean"\cf2 , raw.f0_mean_hz) \cf7 if\cf2  raw.f0_mean_hz \cf7 else\cf2  \cf4 0.0\cf2 ,             \
          z_energy=baseline.z_score(\cf5 "rms_db"\cf2 , raw.rms_db),                                         \
          z_pause_before=baseline.z_score(\cf5 "pause_ms"\cf2 , raw.pause_before_ms),                        \
          z_pause_after=baseline.z_score(\cf5 "pause_ms"\cf2 , raw.pause_after_ms),                          \
          z_duration=baseline.z_score(\cf5 "duration_ms"\cf2 , raw.duration_ms),                             \
          z_spectral_centroid=baseline.z_score(\cf5 "spectral_centroid"\cf2 , raw.spectral_centroid_hz),     \
                                                                                                   \
          word_count_ratio=(                                                                       \
              raw.word_count_spoken / \cf8 max\cf2 (raw.word_count_expected, \cf4 1\cf2 )                              \
          ),                                                                                       \
          duration_ratio=(\
              raw.duration_ms / \cf8 max\cf2 (baseline.expected_duration_ms(raw.word_count_expected), \cf4 1\cf2 )     \
          ),                                                                                       \
          energy_variance_ratio=_energy_variance_ratio(raw.energy_contour, baseline),\
                                                                                                   \
          delta_energy_prev=raw.rms_db - neighbors.prev_rms_db,                                    \
          delta_energy_next=neighbors.next_rms_db - raw.rms_db,                                    \
          delta_f0_prev=_safe_delta(raw.f0_mean_hz, neighbors.prev_f0_hz),                         \
          delta_f0_next=_safe_delta(neighbors.next_f0_hz, raw.f0_mean_hz),                         \
          delta_rate_prev=raw.speech_rate_wps - neighbors.prev_rate_wps,\
          delta_rate_next=neighbors.next_rate_wps - raw.speech_rate_wps,                           \
                  \
          levenshtein_distance=_levenshtein(raw.expected_text, raw.spoken_text),                   \
          levenshtein_ratio=_levenshtein_ratio(raw.expected_text, raw.spoken_text),\
          token_overlap_ratio=_jaccard(raw.expected_text.split(), raw.spoken_text.split()),        \
          has_shared_prefix=_has_shared_prefix(raw.expected_text, raw.spoken_text),                \
          shared_prefix_length=_shared_prefix_length(raw.expected_text, raw.spoken_text),          \
                                                                                                   \
          silence_fraction=_silence_fraction(raw),                                                 \
          is_isolated_speech=(raw.pause_before_ms > \cf4 800\cf2  \cf7 and\cf2  raw.pause_after_ms > \cf4 800\cf2 ),             \
      )                                                                                            \
                  \
