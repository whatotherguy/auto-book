  \cf7 class WeakLandingDetector:\cf2 \
      \cf5 """Detects weak sentence endings \'97 trailing energy drop or pitch collapse."""\cf2 \
                                                                                                   \
      name = \cf5 "weak_landing"\cf2 \
                                                                                                   \
      \cf7 def\cf9  evaluate(self, raw: RawFeatureCatalog, derived: DerivedFeatures) -> DetectorOutput:\cf2       \
          score = \cf4 0.0\cf2 \
          reasons = []                                                                             \
                  \
          \cf4 # Energy drops in the last quarter of the segment\cf2                                         \
          \cf7 if\cf2  \cf8 len\cf2 (raw.energy_contour) >= \cf4 8\cf2 :\
              last_quarter = raw.energy_contour[-(\cf8 len\cf2 (raw.energy_contour) // \cf4 4\cf2 ):]                  \
              first_three_quarters = raw.energy_contour[:-(\cf8 len\cf2 (raw.energy_contour) // \cf4 4\cf2 )]          \
              \cf7 if\cf2  first_three_quarters:                                                             \
                  mean_first = \cf8 sum\cf2 (first_three_quarters) / \cf8 len\cf2 (first_three_quarters)               \
                  mean_last = \cf8 sum\cf2 (last_quarter) / \cf8 len\cf2 (last_quarter)                                \
                  \cf7 if\cf2  mean_first > \cf4 0\cf2 :\
                      drop_ratio = mean_last / mean_first                                          \
                      \cf7 if\cf2  drop_ratio < \cf4 0.3\cf2 :                                                         \
                          score = \cf4 0.7\cf2 \
                          reasons.append(\cf5 f"Energy drops to \{drop_ratio:\cf4 .0\cf5 %\} at segment end"\cf2 )       \
                      \cf7 elif\cf2  drop_ratio < \cf4 0.5\cf2 :                                                       \
                          score = \cf4 0.4\cf2                                                               \
                          reasons.append(\cf5 f"Energy fades to \{drop_ratio:\cf4 .0\cf5 %\} at segment end"\cf2 )       \
                  \
          \cf4 # F0 collapse (pitch drops below speaker floor)\cf2                                           \
          \cf7 if\cf2  raw.f0_contour \cf7 and\cf2  \cf8 len\cf2 (raw.f0_contour) >= \cf4 4\cf2 :\
              last_f0 = raw.f0_contour[-\cf4 2\cf2 :]                                                        \
              \cf7 if\cf2  raw.f0_mean_hz \cf7 and\cf2  \cf8 all\cf2 (f < raw.f0_mean_hz * \cf4 0.7\cf2  \cf7 for\cf2  f \cf7 in\cf2  last_f0):                \
                  score = \cf8 max\cf2 (score, \cf4 0.5\cf2 )                                                          \
                  reasons.append(\cf5 "Pitch collapses at segment end"\cf2 )                                 \
                                                                                                   \
          \cf4 # Only meaningful at actual sentence ends\cf2                                                 \
          \cf7 if\cf2  \cf7 not\cf2  raw.is_last_sentence \cf7 and\cf2  \cf7 not\cf2  raw.at_paragraph_boundary:                           \
              score *= \cf4 0.4\cf2                                                                          \
              reasons.append(\cf5 "Not at sentence boundary \'97 reduced weight"\cf2 )\
                                                                                                   \
          confidence = \cf4 0.5\cf2                                                                          \
                                                                                                   \
          \cf7 return\cf2  DetectorOutput(                                                                   \
              detector_name=self.name,\
              score=\cf8 round\cf2 (score, \cf4 4\cf2 ),\
              confidence=\cf8 round\cf2 (confidence, \cf4 4\cf2 ),\
              reasons=reasons,\
              features_used=\{                                                                      \
                  \cf5 "energy_contour_length"\cf2 : \cf8 len\cf2 (raw.energy_contour),\
                  \cf5 "f0_contour_length"\cf2 : \cf8 len\cf2 (raw.f0_contour) \cf7 if\cf2  raw.f0_contour \cf7 else\cf2  \cf4 0\cf2 ,               \
              \},                                                                                   \
              triggered=score >= \cf4 0.3\cf2 ,                                                              \
