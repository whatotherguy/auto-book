          click = amplitude * np.random.randn(click_duration) * np.hanning(click_duration)         \
          end = \cf8 min\cf2 (sample + click_duration, \cf8 len\cf2 (y))                                               \
          y[sample:end] += click[:end - sample]                                                    \
          \cf7 return\cf2  y                                                                                 \
                  \
      \cf7 def\cf9  inject_pause(self, y: np.ndarray, sr: \cf8 int\cf9 , position_ms: \cf8 int\cf9 ,\cf2                              \
  \cf9                      duration_ms: \cf8 int\cf9  = \cf4 2000\cf9 ) -> np.ndarray:\cf2 \
