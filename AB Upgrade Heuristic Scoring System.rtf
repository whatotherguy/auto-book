  \cf7 class FlatDeliveryDetector:\cf2                                                                       \
      \cf5 """Detects monotone delivery \'97 low pitch and energy variation."""\cf2 \
                                                                                                   \
      name = \cf5 "flat_delivery"\cf2                                                                        \
                                                                                                   \
      \cf7 def\cf9  evaluate(self, raw: RawFeatureCatalog, derived: DerivedFeatures) -> DetectorOutput:\cf2       \
          score = \cf4 0.0\cf2 \
          reasons = []\
\
          \cf4 # Low F0 variation (monotone)\cf2                                                             \
          \cf7 if\cf2  raw.f0_std_hz \cf7 is\cf2  \cf7 not\cf2  \cf7 None\cf2  \cf7 and\cf2  raw.f0_std_hz < \cf4 8.0\cf2 :\
              score = \cf8 max\cf2 (score, \cf4 0.6\cf2  + \cf4 0.4\cf2  * \cf8 max\cf2 (\cf4 0\cf2 , \cf4 1.0\cf2  - raw.f0_std_hz / \cf4 8.0\cf2 ))                    \
              reasons.append(\cf5 f"Low pitch variation: F0 std=\{raw.f0_std_hz:\cf4 .1\cf5 f\}Hz"\cf2 )                 \
                                                                                                   \
          \cf4 # Low energy variation (flat dynamics)\cf2                                                    \
          \cf7 if\cf2  derived.energy_variance_ratio < \cf4 0.4\cf2 :                                                  \
              score = \cf8 max\cf2 (score, \cf4 0.5\cf2 )                                                              \
              reasons.append(\cf5 f"Flat dynamics: energy variance \cf2 \
  \cf5 ratio=\{derived.energy_variance_ratio:\cf4 .2\cf5 f\}"\cf2 )                                                      \
  \
          \cf4 # Only meaningful for longer segments (3+ words)\cf2                                          \
          \cf7 if\cf2  raw.word_count_spoken < \cf4 3\cf2 :\
              score *= \cf4 0.3\cf2                                                                          \
              reasons.append(\cf5 "Short segment \'97 prosody unreliable"\cf2 )\
                                                                                                   \
          confidence = \cf4 0.55\cf2  \cf7 if\cf2  raw.word_count_spoken >= \cf4 5\cf2  \cf7 else\cf2  \cf4 0.35\cf2                                 \
                                                                                                   \
          \cf7 return\cf2  DetectorOutput(                                                                   \
              detector_name=self.name,\
              score=\cf8 round\cf2 (score, \cf4 4\cf2 ),\
              confidence=\cf8 round\cf2 (confidence, \cf4 4\cf2 ),\
              reasons=reasons,\
              features_used=\{\
                  \cf5 "f0_std_hz"\cf2 : raw.f0_std_hz,\
                  \cf5 "energy_variance_ratio"\cf2 : derived.energy_variance_ratio,                          \
                  \cf5 "word_count_spoken"\cf2 : raw.word_count_spoken,                                      \
              \},                                                                                   \
              triggered=score >= \cf4 0.4\cf2 ,                                                              \
          )                                                                                        \
