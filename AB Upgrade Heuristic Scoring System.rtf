          \cf7 return\cf2  tokens                                                                            \
                                                                                                   \
      \cf7 def\cf9  inject_gain_shift(self, y: np.ndarray, sr: \cf8 int\cf9 , position_ms: \cf8 int\cf9 ,\cf2                         \
  \cf9                           gain_db: \cf8 float\cf9  = \cf4 6.0\cf9 ) -> np.ndarray:\cf2 \
