\f2\b 3B. Pickup Candidate Score
\f1\b0                                                                        \
                  \
  
\f2\b Question answered
\f1\b0 : "How likely is this a narrator restart/pickup?"                               \
  \
  PICKUP_WEIGHTS = \{                                                                               \
      \cf5 "pickup_pattern"\cf2 :    \cf4 0.35\cf2 ,   \cf4 # compound pickup signal detection\cf2 \
      \cf5 "restart_gap"\cf2 :       \cf4 0.25\cf2 ,   \cf4 # timing pattern of isolated utterance\cf2                           \
      \cf5 "click_transient"\cf2 :   \cf4 0.15\cf2 ,   \cf4 # edit marker near segment\cf2                                       \
      \cf5 "repeated_phrase"\cf2 :   \cf4 0.10\cf2 ,   \cf4 # text re-read pattern\cf2                                           \
      \cf5 "abnormal_pause"\cf2 :    \cf4 0.10\cf2 ,   \cf4 # unusual silence around segment\cf2                                 \
      \cf5 "punch_in_boundary"\cf2 : \cf4 0.05\cf2 ,   \cf4 # audio edit point\cf2                                               \
  \}                                                                                                \
                                                                                                   \
  \cf7 def\cf9  compute_pickup_candidate_score(\cf2                                                               \
  \cf9     detectors: \cf8 dict\cf9 [\cf8 str\cf9 , DetectorOutput],\cf2                                                         \
  \cf9 ) -> ScoredResult:\cf2                                                                                \
      score = \cf4 0.0\cf2  \
      components = \{\}                                                                              \
      reasons = []\
      ambiguity = []                                                                               \
                  \
      \cf7 for\cf2  det_name, weight \cf7 in\cf2  PICKUP_WEIGHTS.items():                                              \
          det = detectors.get(det_name)\
          \cf7 if\cf2  det \cf7 is\cf2  \cf7 None\cf2 :                                                                          \
              \cf7 continue\cf2 \
          weighted = det.score * det.confidence * weight\
          components[det_name] = \cf8 round\cf2 (weighted, \cf4 4\cf2 )\
          score += weighted                                                                        \
          \cf7 if\cf2  det.triggered:\
              reasons.extend(det.reasons)                                                          \
                  \
      score = \cf8 min\cf2 (\cf4 1.0\cf2 , score / \cf8 sum\cf2 (PICKUP_WEIGHTS.values()))                                       \
                  \
      \cf4 # Boost: if both pickup_pattern AND restart_gap fire, strong signal\cf2                           \
      \cf7 if\cf2  (detectors.get(\cf5 "pickup_pattern"\cf2 , _NULL).triggered\
          \cf7 and\cf2  detectors.get(\cf5 "restart_gap"\cf2 , _NULL).triggered):                                      \
          score = \cf8 min\cf2 (\cf4 1.0\cf2 , score * \cf4 1.3\cf2 )\
          reasons.append(\cf5 "Multiple independent pickup signals converge"\cf2 )                           \
                  \
      \cf4 # Ambiguity\cf2                                                                                   \
      \cf7 if\cf2  score > \cf4 0.5\cf2  \cf7 and\cf2  \cf7 not\cf2  detectors.get(\cf5 "repeated_phrase"\cf2 , _NULL).triggered:\
          ambiguity.append(\cf5 "Timing suggests pickup but no text repetition found"\cf2 )                  \
                                                                                                   \
      confidence = _aggregate_confidence(detectors, PICKUP_WEIGHTS)                                \
                                                                                                   \
      \cf7 return\cf2  ScoredResult(\
          score=\cf8 round\cf2 (score, \cf4 4\cf2 ), confidence=\cf8 round\cf2 (confidence, \cf4 4\cf2 ),\
          components=components, reasons=reasons, ambiguity_flags=ambiguity,                       \
      )\
                                                                                                   \
  
\f2\b 3C. Performance Quality Score
\f1\b0 \
\
  
\f2\b Question answered
\f1\b0 : "How well was this segment performed?"                                        \
  \
  PERFORMANCE_WEIGHTS = \{                                                                          \
      \cf5 "flat_delivery"\cf2 :     -\cf4 0.30\cf2 ,  \cf4 # negative: flat = lower quality\cf2 \
      \cf5 "weak_landing"\cf2 :      -\cf4 0.20\cf2 ,  \cf4 # negative: weak ending = lower quality\cf2                          \
      \cf5 "cadence_drift"\cf2 :     -\cf4 0.15\cf2 ,  \cf4 # negative: inconsistent pacing\cf2 \
      \cf5 "rushed_delivery"\cf2 :   -\cf4 0.15\cf2 ,  \cf4 # negative: too fast\cf2                                             \
      \cf5 "clipping"\cf2 :          -\cf4 0.10\cf2 ,  \cf4 # negative: audio quality issue\cf2 \
      \cf5 "room_tone_shift"\cf2 :   -\cf4 0.10\cf2 ,  \cf4 # negative: environmental inconsistency\cf2                          \
  \}               \
                                                                                                   \
  \cf7 def\cf9  compute_performance_quality_score(\cf2 \
  \cf9     detectors: \cf8 dict\cf9 [\cf8 str\cf9 , DetectorOutput],\cf2 \
  \cf9 ) -> ScoredResult:\cf2                                                                                \
      \cf5 """\cf2 \
  \cf5     Returns 1.0 = excellent performance, 0.0 = poor performance.\cf2                                  \
  \cf5     Starts at 1.0, each triggered detector reduces the score.\cf2                                     \
  \cf5     """\cf2                                                                                           \
      score = \cf4 1.0\cf2                                                                                   \
      components = \{\}                                                                              \
      reasons = []\
      ambiguity = []                                                                               \
                  \
      \cf7 for\cf2  det_name, penalty_weight \cf7 in\cf2  PERFORMANCE_WEIGHTS.items():                                 \
          det = detectors.get(det_name)\
          \cf7 if\cf2  det \cf7 is\cf2  \cf7 None\cf2 :                                                                          \
              \cf7 continue\cf2 \
          penalty = det.score * det.confidence * \cf8 abs\cf2 (penalty_weight)\
          components[det_name] = \cf8 round\cf2 (-penalty, \cf4 4\cf2 )                                                \
          score -= penalty\
          \cf7 if\cf2  det.triggered:                                                                        \
              reasons.extend(det.reasons)\
\
      score = \cf8 max\cf2 (\cf4 0.0\cf2 , \cf8 min\cf2 (\cf4 1.0\cf2 , score))                                                            \
  \
      \cf4 # Ambiguity: very short segments don't have reliable prosody\cf2                                  \
      prosody_detectors = [\cf5 "flat_delivery"\cf2 , \cf5 "weak_landing"\cf2 , \cf5 "cadence_drift"\cf2 ]\
      \cf7 if\cf2  \cf8 any\cf2 (detectors.get(d, _NULL).triggered \cf7 for\cf2  d \cf7 in\cf2  prosody_detectors):                        \
          ambiguity.append(\cf5 "Prosody detectors are less reliable for segments under 3 words"\cf2 )       \
                                                                                                   \
      confidence = _aggregate_confidence(detectors, \{k: \cf8 abs\cf2 (v) \cf7 for\cf2  k, v \cf7 in\cf2                          \
  PERFORMANCE_WEIGHTS.items()\})                                                                    \
                                                                                                   \
      \cf7 return\cf2  ScoredResult(\
          score=\cf8 round\cf2 (score, \cf4 4\cf2 ), confidence=\cf8 round\cf2 (confidence, \cf4 4\cf2 ),\
          components=components, reasons=reasons, ambiguity_flags=ambiguity,\
      )                                                                                            \
  \
  
\f2\b 3D. Continuity Fit Score
\f1\b0                                                                          \
                  \
  
\f2\b Question answered
\f1\b0 : "How well does this segment fit with its neighbors?"                          \
  \
  CONTINUITY_WEIGHTS = \{                                                                           \
      \cf5 "continuity_mismatch"\cf2 : -\cf4 0.40\cf2 ,  \cf4 # direct continuity measurement\cf2 \
      \cf5 "room_tone_shift"\cf2 :     -\cf4 0.25\cf2 ,  \cf4 # environmental discontinuity\cf2                                  \
      \cf5 "punch_in_boundary"\cf2 :   -\cf4 0.20\cf2 ,  \cf4 # edit point detected\cf2                                          \
      \cf5 "cadence_drift"\cf2 :       -\cf4 0.15\cf2 ,  \cf4 # pacing break\cf2                                                 \
  \}                                                                                                \
                  \
  \cf7 def\cf9  compute_continuity_fit_score(\cf2                                                                 \
  \cf9     detectors: \cf8 dict\cf9 [\cf8 str\cf9 , DetectorOutput],\cf2 \
  \cf9 ) -> ScoredResult:\cf2                                                                                \
      \cf5 """Returns 1.0 = seamless continuity, 0.0 = obvious discontinuity."""\cf2 \
      score = \cf4 1.0\cf2                                                                                   \
      components = \{\}\
      reasons = []                                                                                 \
      ambiguity = []\
\
      \cf7 for\cf2  det_name, penalty_weight \cf7 in\cf2  CONTINUITY_WEIGHTS.items():\
          det = detectors.get(det_name)\
          \cf7 if\cf2  det \cf7 is\cf2  \cf7 None\cf2 :                                                                          \
              \cf7 continue\cf2 \
          penalty = det.score * det.confidence * \cf8 abs\cf2 (penalty_weight)                               \
          components[det_name] = \cf8 round\cf2 (-penalty, \cf4 4\cf2 )\
          score -= penalty\
          \cf7 if\cf2  det.triggered:\
              reasons.extend(det.reasons)\
                                                                                                   \
      score = \cf8 max\cf2 (\cf4 0.0\cf2 , \cf8 min\cf2 (\cf4 1.0\cf2 , score))\
                                                                                                   \
      \cf4 # Ambiguity: first/last segments have no neighbor on one side\cf2                                 \
      ambiguity_note = \cf7 None\cf2   \cf4 # set from raw features in caller if needed\cf2 \
                                                                                                   \
      confidence = _aggregate_confidence(detectors, \{k: \cf8 abs\cf2 (v) \cf7 for\cf2  k, v \cf7 in\cf2                          \
  CONTINUITY_WEIGHTS.items()\})                                                                     \
                                                                                                   \
      \cf7 return\cf2  ScoredResult(\
          score=\cf8 round\cf2 (score, \cf4 4\cf2 ), confidence=\cf8 round\cf2 (confidence, \cf4 4\cf2 ),\
          components=components, reasons=reasons, ambiguity_flags=ambiguity,\
      )                                                                                            \
  \
  
\f2\b 3E. Splice Readiness Score
\f1\b0                                                                        \
                  \
  
\f2\b Question answered
\f1\b0 : "Can this segment be safely auto-cut or auto-spliced?"                        \
  \
  \cf7 def\cf9  compute_splice_readiness_score(\cf2                                                               \
  \cf9     detectors: \cf8 dict\cf9 [\cf8 str\cf9 , DetectorOutput],\cf2 \
  \cf9     composite: \cf8 dict\cf9 ,  \cf4 # already-computed composites\cf2 \
  \cf9 ) -> ScoredResult:\cf2                                                                                \
      \cf5 """\cf2 \
  \cf5     High score = safe to auto-edit.\cf2                                                               \
  \cf5     Requires: high mistake/pickup confidence AND good splice-in/out quality.\cf2 \
                                                                                                   \
  \cf5     Formula:\cf2     \
  \cf5       splice_readiness = actionability \'d7 splice_safety\cf2                                            \
                                                                                                   \
  \cf5     Where:\cf2                                                                                        \
  \cf5       actionability = max(mistake_score, pickup_score) \'d7 confidence\cf2                               \
  \cf5       splice_safety = (1 - punch_in_score) \'d7 (1 - clipping_score)\cf2                                 \
  \cf5     """\cf2                                                                                           \
      reasons = []\
      ambiguity = []                                                                               \
                  \
      mistake = composite[\cf5 "mistake_candidate"\cf2 ]                                                     \
      pickup = composite[\cf5 "pickup_candidate"\cf2 ]\
      continuity = composite[\cf5 "continuity_fit"\cf2 ]                                                     \
                                                                                                   \
      \cf4 # Actionability: how confident are we this needs editing?\cf2                                     \
      actionability = \cf8 max\cf2 (                                                                         \
          mistake.score * mistake.confidence,                                                      \
          pickup.score * pickup.confidence,\
      )\
                                                                                                   \
      \cf4 # Splice safety: are the edit points clean?\cf2 \
      punch_in = detectors.get(\cf5 "punch_in_boundary"\cf2 , _NULL)                                         \
      clipping = detectors.get(\cf5 "clipping"\cf2 , _NULL)                                                  \
                                                                                                   \
      \cf4 # Counterintuitively, a detected punch-in boundary HELPS splice safety\cf2                        \
      \cf4 # because the existing edit point is a natural splice location\cf2                                \
      splice_safety = \cf4 1.0\cf2                                                                           \
      \cf7 if\cf2  clipping.triggered:\
          splice_safety -= \cf4 0.3\cf2  * clipping.score                                                    \
          reasons.append(\cf5 "Clipping near edit point reduces splice safety"\cf2 )                         \
   \
      \cf4 # Room tone consistency matters for clean splices\cf2                                             \
      room_tone = detectors.get(\cf5 "room_tone_shift"\cf2 , _NULL)\
      \cf7 if\cf2  room_tone.triggered:                                                                      \
          splice_safety -= \cf4 0.2\cf2  * room_tone.score                                                   \
          reasons.append(\cf5 "Room tone shift may cause audible splice"\cf2 )                               \
                                                                                                   \
      splice_safety = \cf8 max\cf2 (\cf4 0.0\cf2 , splice_safety)                                                      \
                  \
      \cf4 # Final score\cf2                                                                                 \
      score = actionability * splice_safety\
                                                                                                   \
      \cf7 if\cf2  actionability > \cf4 0.7\cf2 :\
          reasons.append(\cf5 f"High actionability: \{actionability:\cf4 .2\cf5 f\}"\cf2 )\
      \cf7 if\cf2  splice_safety < \cf4 0.6\cf2 :                                                                      \
          ambiguity.append(\cf5 "Splice safety concerns \'97 manual review recommended"\cf2 )\
      \cf7 if\cf2  actionability < \cf4 0.4\cf2 :                                                                      \
          ambiguity.append(\cf5 "Low confidence in whether this needs editing"\cf2 )\
                                                                                                   \
      confidence = \cf8 min\cf2 (mistake.confidence, pickup.confidence, \cf4 0.5\cf2  + splice_safety * \cf4 0.5\cf2 )           \
                                                                                                   \
      \cf7 return\cf2  ScoredResult(                                                                         \
          score=\cf8 round\cf2 (\cf8 min\cf2 (\cf4 1.0\cf2 , score), \cf4 4\cf2 ),\
          confidence=\cf8 round\cf2 (confidence, \cf4 4\cf2 ),                                                         \
          components=\{\
              \cf5 "actionability"\cf2 : \cf8 round\cf2 (actionability, \cf4 4\cf2 ),                                            \
              \cf5 "splice_safety"\cf2 : \cf8 round\cf2 (splice_safety, \cf4 4\cf2 ),\
          \},                                                                                       \
          reasons=reasons,                                                                         \
          ambiguity_flags=ambiguity,\
      )                                                                                            \
                  \
  
\f2\b 3F. Alternate Take Preference Score
\f1\b0                                                               \
                  \
  
\f2\b Question answered
\f1\b0 : "Which take should be kept in a cluster of alternate takes?"                  \
   \
  This is computed per-cluster, not per-segment.                                                   \
                  \
  \cf4 # File: services/scoring/take_ranking.py\cf2                                                          \
                                                                                                   \
  \cf6 @dataclass\cf2 \
  \cf7 class TakeRanking:\cf2                                                                                \
      \cf5 """Ranking result for an alt-take cluster."""\cf2 \
      cluster_id: \cf8 str\cf2 \
      ranked_takes: \cf8 list\cf2 [RankedTake]     \cf4 # best-first ordering\cf2                                      \
      preferred_take_issue_id: \cf8 int\cf2  | \cf7 None\cf2 \
      selection_reasons: \cf8 list\cf2 [\cf8 str\cf2 ]                                                                 \
      confidence: \cf8 float\cf2                                                                             \
                                                                                                   \
  \cf6 @dataclass\cf2                                                                                        \
  \cf7 class RankedTake:\cf2                                                                                 \
      issue_id: \cf8 int\cf2  | \cf7 None\cf2 \
      issue_index: \cf8 int\cf2 \
      rank: \cf8 int\cf2                           \cf4 # 1 = best\cf2                                                 \
      total_score: \cf8 float\cf2                  \cf4 # composite preference score\cf2 \
      performance_quality: \cf8 float\cf2                                                                    \
      continuity_fit: \cf8 float\cf2 \
      text_accuracy: \cf8 float\cf2                                                                          \
      splice_readiness: \cf8 float\cf2                                                                       \
      reasons: \cf8 list\cf2 [\cf8 str\cf2 ]\
                                                                                                   \
                  \
  TAKE_PREFERENCE_WEIGHTS = \{                                                                      \
      \cf5 "text_accuracy"\cf2 :        \cf4 0.35\cf2 ,   \cf4 # must say the right words\cf2 \
      \cf5 "performance_quality"\cf2 :  \cf4 0.30\cf2 ,   \cf4 # must sound good\cf2                                             \
      \cf5 "continuity_fit"\cf2 :       \cf4 0.25\cf2 ,   \cf4 # must fit with surrounding audio\cf2                             \
      \cf5 "splice_readiness"\cf2 :     \cf4 0.10\cf2 ,   \cf4 # editing convenience\cf2                                         \
  \}                                                                                                \
                  \
  \cf7 def\cf9  rank_alternate_takes(\cf2                                                                         \
  \cf9     cluster_members: \cf8 list\cf9 [\cf8 dict\cf9 ],       \cf4 # [\{issue_index, issue, composites, detectors\}]\cf2 \
  \cf9     neighbor_context: \cf5 "NeighborContext"\cf9 ,\cf2                                                          \
  \cf9 ) -> TakeRanking:\cf2 \
      \cf5 """\cf2                                                                                           \
  \cf5     Rank takes within a cluster.\cf2 \
                                                                                                   \
  \cf5     Each take is scored on four dimensions. The take with the highest\cf2                             \
  \cf5     weighted total is preferred.\cf2                                                                  \
                                                                                                   \
  \cf5     Tie-breaking rules (applied in order):\cf2 \
  \cf5     1. Higher text accuracy wins\cf2                                                                  \
  \cf5     2. Higher continuity fit wins (better transitions)\cf2                                            \
  \cf5     3. Later take wins (narrator typically improves on retry)\cf2 \
  \cf5     """\cf2                                                                                           \
      ranked = [] \
                                                                                                   \
      \cf7 for\cf2  member \cf7 in\cf2  cluster_members:\
          composites = member[\cf5 "composites"\cf2 ]                                                        \
          detectors = member[\cf5 "detectors"\cf2 ]                                                          \
          issue = member[\cf5 "issue"\cf2 ]\
                                                                                                   \
          \cf4 # Text accuracy: inverse of mistake score\cf2 \
          text_accuracy = \cf4 1.0\cf2  - composites[\cf5 "mistake_candidate"\cf2 ].score                              \
                  \
          \cf4 # Direct from composites\cf2                                                                  \
          perf = composites[\cf5 "performance_quality"\cf2 ].score\
          cont = composites[\cf5 "continuity_fit"\cf2 ].score                                                \
          splice = composites[\cf5 "splice_readiness"\cf2 ].score                                            \
                                                                                                   \
          total = (                                                                                \
              TAKE_PREFERENCE_WEIGHTS[\cf5 "text_accuracy"\cf2 ] * text_accuracy                             \
              + TAKE_PREFERENCE_WEIGHTS[\cf5 "performance_quality"\cf2 ] * perf\
              + TAKE_PREFERENCE_WEIGHTS[\cf5 "continuity_fit"\cf2 ] * cont                                   \
              + TAKE_PREFERENCE_WEIGHTS[\cf5 "splice_readiness"\cf2 ] * splice\
          )                                                                                        \
                  \
          reasons = []\
          \cf7 if\cf2  text_accuracy > \cf4 0.9\cf2 :\
              reasons.append(\cf5 "Accurate text"\cf2 )                                                      \
          \cf7 if\cf2  perf > \cf4 0.8\cf2 :\
              reasons.append(\cf5 "Strong performance"\cf2 )                                                 \
          \cf7 if\cf2  cont > \cf4 0.8\cf2 :\
              reasons.append(\cf5 "Good continuity with context"\cf2 )                                       \
  \
          ranked.append(RankedTake(                                                                \
              issue_id=issue.get(\cf5 "id"\cf2 ),\
              issue_index=member[\cf5 "issue_index"\cf2 ],                                                   \
              rank=\cf4 0\cf2 ,  \cf4 # set below\cf2 \
              total_score=\cf8 round\cf2 (total, \cf4 4\cf2 ),                                                         \
              performance_quality=\cf8 round\cf2 (perf, \cf4 4\cf2 ),                                                  \
              continuity_fit=\cf8 round\cf2 (cont, \cf4 4\cf2 ),\
              text_accuracy=\cf8 round\cf2 (text_accuracy, \cf4 4\cf2 ),                                               \
              splice_readiness=\cf8 round\cf2 (splice, \cf4 4\cf2 ),\
              reasons=reasons,                                                                     \
          ))\
                                                                                                   \
      \cf4 # Sort: highest total first, tie-break by text_accuracy, then continuity,\cf2                     \
      \cf4 # then take_order (later = better)\cf2 \
      ranked.sort(key=\cf7 lambda\cf2  t: (                                                                  \
          -t.total_score,                                                                          \
          -t.text_accuracy,\
          -t.continuity_fit,                                                                       \
          -t.issue_index,  \cf4 # later index = later take\cf2 \
      ))                                                                                           \
  \
      \cf7 for\cf2  i, take \cf7 in\cf2  \cf8 enumerate\cf2 (ranked):                                                            \
          take.rank = i + \cf4 1\cf2 \
                                                                                                   \
      selection_reasons = []                                                                       \
      \cf7 if\cf2  \cf8 len\cf2 (ranked) >= \cf4 2\cf2 :\
          gap = ranked[\cf4 0\cf2 ].total_score - ranked[\cf4 1\cf2 ].total_score                                      \
          \cf7 if\cf2  gap < \cf4 0.05\cf2 :\
              selection_reasons.append(\
                  \cf5 f"Close call: top two takes differ by only \{gap:\cf4 .3\cf5 f\}"\cf2                             \
              )                                                                                    \
          \cf7 else\cf2 :                                                                                    \
              selection_reasons.append(                                                            \
                  \cf5 f"Clear preference: top take leads by \{gap:\cf4 .3\cf5 f\}"\cf2 \
              )                                                                                    \
                  \
      confidence = \cf4 0.7\cf2                                                                              \
      \cf7 if\cf2  \cf8 len\cf2 (ranked) >= \cf4 2\cf2  \cf7 and\cf2  ranked[\cf4 0\cf2 ].total_score - ranked[\cf4 1\cf2 ].total_score > \cf4 0.1\cf2 :\
          confidence = \cf4 0.85\cf2                                                                         \
  \
      \cf7 return\cf2  TakeRanking(                                                                          \
          cluster_id=cluster_members[\cf4 0\cf2 ].get(\cf5 "cluster_id"\cf2 , \cf5 ""\cf2 ),\
          ranked_takes=ranked,                                                                     \
          preferred_take_issue_id=ranked[\cf4 0\cf2 ].issue_id \cf7 if\cf2  ranked \cf7 else\cf2  \cf7 None\cf2 ,\
          selection_reasons=selection_reasons,                                                     \
          confidence=\cf8 round\cf2 (confidence, \cf4 4\cf2 ),\
      )                                                                                            \
                  \
