          y = y.copy()                                                                             \
          sample = \cf8 int\cf2 (position_ms / \cf4 1000\cf2  * sr)                                                    \
          silence_samples = \cf8 int\cf2 (duration_ms / \cf4 1000\cf2  * sr)                                           \
          \cf4 # Room tone: very low-level noise\cf2                                                         \
          room_tone = np.random.randn(silence_samples) * \cf4 0.001\cf2                                      \
          y = np.concatenate([y[:sample], room_tone, y[sample:]])                                  \
          \cf7 return\cf2  y                                                                                 \
                                                                                                   \
      \cf7 def\cf9  inject_repeated_phrase(self, spoken_tokens: \cf8 list\cf9 , position: \cf8 int\cf9 ,\cf2                          \
  \cf9                                phrase_length: \cf8 int\cf9  = \cf4 4\cf9 ) -> \cf8 list\cf9 :\cf2 \
