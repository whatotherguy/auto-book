  \cf7 class ScoringResult(SQLModel, table=True):\cf2                                                        \
      \cf5 """Persisted scoring envelope for an issue."""\cf2                                                \
      \cf8 id\cf2 : \cf10 Optional\cf2 [\cf8 int\cf2 ] = Field(default=\cf7 None\cf2 , primary_key=\cf7 True\cf2 )                                    \
      issue_id: \cf8 int\cf2  = Field(foreign_key=\cf5 "issue.id"\cf2 , index=\cf7 True\cf2 )                                    \
      chapter_id: \cf8 int\cf2  = Field(foreign_key=\cf5 "chapter.id"\cf2 , index=\cf7 True\cf2 )                                \
      scoring_version: \cf8 str\cf2  = \cf5 "1.0.0"\cf2                                                                \
                                                                                                   \
      \cf4 # Composite scores (stored as JSON)\cf2                                                           \
      composite_scores_json: \cf8 str\cf2  = \cf5 ""\cf2       \cf4 # JSON: CompositeScores\cf2 \
      detector_outputs_json: \cf8 str\cf2  = \cf5 ""\cf2       \cf4 # JSON: dict[str, DetectorOutput]\cf2                        \
      recommendation_json: \cf8 str\cf2  = \cf5 ""\cf2         \cf4 # JSON: EditorialRecommendation\cf2                          \
      derived_features_json: \cf8 str\cf2  = \cf5 ""\cf2       \cf4 # JSON: DerivedFeatures\cf2                                  \
                                                                                                   \
      \cf4 # Denormalized for query efficiency\cf2                                                           \
      mistake_score: \cf8 float\cf2  = \cf4 0.0\cf2 \
      pickup_score: \cf8 float\cf2  = \cf4 0.0\cf2                                                                     \
      performance_score: \cf8 float\cf2  = \cf4 0.0\cf2 \
      splice_score: \cf8 float\cf2  = \cf4 0.0\cf2 \
      priority: \cf8 str\cf2  = \cf5 "info"\cf2                \cf4 # from recommendation\cf2                                    \
                                                                                                   \
      baseline_id: \cf8 str\cf2  = \cf5 ""\cf2                                                                         \
      created_at: datetime = Field(default_factory=utc_now)                                        \
