          tokens = [\cf8 dict\cf2 (t) \cf7 if\cf2  \cf8 isinstance\cf2 (t, \cf8 dict\cf2 ) \cf7 else\cf2  t \cf7 for\cf2  t \cf7 in\cf2  spoken_tokens]                  \
          \cf7 for\cf2  i \cf7 in\cf2  \cf8 range\cf2 (start, \cf8 min\cf2 (end, \cf8 len\cf2 (tokens))):                                            \
