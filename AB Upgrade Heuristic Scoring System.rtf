              score = \cf8 max\cf2 (score, \cf8 min\cf2 (\cf4 0.8\cf2 , \cf8 abs\cf2 (derived.delta_rate_prev) / \cf4 4.0\cf2 ))                     \
              reasons.append(                                                                      \
                  \cf5 f"Rate change from prev segment: \{derived.delta_rate_prev:+\cf4 .1\cf5 f\} wps"\cf2              \
              )                                                                                    \
                  \
          \cf7 if\cf2  \cf8 abs\cf2 (derived.delta_rate_next) > \cf4 1.5\cf2 :                                                   \
              score = \cf8 max\cf2 (score, \cf8 min\cf2 (\cf4 0.8\cf2 , \cf8 abs\cf2 (derived.delta_rate_next) / \cf4 4.0\cf2 ))\
              reasons.append(                                                                      \
                  \cf5 f"Rate change to next segment: \{derived.delta_rate_next:+\cf4 .1\cf5 f\} wps"\cf2 \
              )                                                                                    \
                  \
          \cf4 # Also flag overall deviation from narrator baseline\cf2                                      \
          \cf7 if\cf2  \cf8 abs\cf2 (derived.z_speech_rate) > \cf4 2.0\cf2 :\
              score = \cf8 max\cf2 (score, \cf4 0.4\cf2 )                                                              \
              reasons.append(\cf5 f"Speech rate z=\{derived.z_speech_rate:+\cf4 .1\cf5 f\}"\cf2 )\
                                                                                                   \
          confidence = \cf4 0.5\cf2 \
                                                                                                   \
          \cf7 return\cf2  DetectorOutput(\
              detector_name=self.name,\
              score=\cf8 round\cf2 (score, \cf4 4\cf2 ),\
              confidence=\cf8 round\cf2 (confidence, \cf4 4\cf2 ),\
              reasons=reasons,                                                                     \
              features_used=\{\
