  \cf7 class CadenceDriftDetector:\cf2 \
      \cf5 """Detects speech rate inconsistency within a segment (accelerating/decelerating)."""\cf2         \
                                                                                                   \
      name = \cf5 "cadence_drift"\cf2                                                                        \
                                                                                                   \
      \cf7 def\cf9  evaluate(self, raw: RawFeatureCatalog, derived: DerivedFeatures) -> DetectorOutput:\cf2       \
          score = \cf4 0.0\cf2 \
