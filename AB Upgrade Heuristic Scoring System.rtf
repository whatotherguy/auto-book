              contribution = \cf8 min\cf2 (\cf4 1.0\cf2 , (derived.z_pause_before - self.LONG_PAUSE_Z) / \cf4 3.0\cf2 )\
              score = \cf8 max\cf2 (score, \cf4 0.4\cf2  + \cf4 0.5\cf2  * contribution)                                         \
              reasons.append(                                                                      \
                  \cf5 f"Pause before: \{raw.pause_before_ms\}ms "\cf2                                         \
                  \cf5 f"(z=\{derived.z_pause_before:+\cf4 .1\cf5 f\})"\cf2                                              \
              )   \
                                                                                                   \
          \cf4 # Long pause after segment\cf2                                                                \
          \cf7 if\cf2  derived.z_pause_after > self.LONG_PAUSE_Z:\
              contribution = \cf8 min\cf2 (\cf4 1.0\cf2 , (derived.z_pause_after - self.LONG_PAUSE_Z) / \cf4 3.0\cf2 )           \
              score = \cf8 max\cf2 (score, \cf4 0.4\cf2  + \cf4 0.5\cf2  * contribution)\
              reasons.append(                                                                      \
                  \cf5 f"Pause after: \{raw.pause_after_ms\}ms "\cf2 \
                  \cf5 f"(z=\{derived.z_pause_after:+\cf4 .1\cf5 f\})"\cf2                                               \
              )                                                                                    \
  \
          \cf4 # Context: pauses at sentence boundaries are less suspicious\cf2                              \
          \cf7 if\cf2  raw.at_paragraph_boundary \cf7 or\cf2  raw.is_last_sentence:\
