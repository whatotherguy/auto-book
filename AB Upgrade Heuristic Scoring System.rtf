      \cf7 def\cf9  evaluate(self, raw: RawFeatureCatalog, derived: DerivedFeatures,\cf2                          \
  \cf9                  audio_signals: \cf8 list\cf9 [\cf8 dict\cf9 ] | \cf7 None\cf9  = \cf7 None\cf9 ,\cf2 \
  \cf9                  vad_segments: \cf8 list\cf9 [\cf8 dict\cf9 ] | \cf7 None\cf9  = \cf7 None\cf9 ) -> DetectorOutput:\cf2                       \
          score = \cf4 0.0\cf2                                                                               \
          reasons = []                                                                             \
          signal_count = \cf4 0\cf2                                                                          \
                  \
          \cf4 # Signal 1: Preceded by long silence\cf2                                                      \
          \cf7 if\cf2  derived.z_pause_before > \cf4 1.5\cf2 :\
              signal_count += \cf4 1\cf2                                                                     \
              reasons.append(\cf5 f"Long pause before: \{raw.pause_before_ms\}ms"\cf2 )\
                                                                                                   \
          \cf4 # Signal 2: Click marker near start\cf2                                                       \
          clicks_near = [                                                                          \
              s \cf7 for\cf2  s \cf7 in\cf2  (audio_signals \cf7 or\cf2  [])                                                     \
              \cf7 if\cf2  s[\cf5 "signal_type"\cf2 ] == \cf5 "click_marker"\cf2 \
              \cf7 and\cf2  \cf8 abs\cf2 (s[\cf5 "start_ms"\cf2 ] - raw.start_ms) < \cf4 2000\cf2 \
          ]                                                                                        \
          \cf7 if\cf2  clicks_near:\
              signal_count += \cf4 1\cf2                                                                     \
              reasons.append(\cf5 f"Click marker \{\cf8 abs\cf5 (clicks_near[\cf4 0\cf5 ]['start_ms'] - raw.start_ms)\}ms from\cf2 \
  \cf5  segment start"\cf2 )                                                                                 \
  \
          \cf4 # Signal 3: Text shares prefix with nearby segment (re-read)\cf2                              \
          \cf7 if\cf2  derived.has_shared_prefix \cf7 and\cf2  derived.shared_prefix_length >= \cf4 3\cf2 :\
              signal_count += \cf4 1\cf2                                                                     \
              reasons.append(\cf5 f"Shared prefix with nearby text: \{derived.shared_prefix_length\} \cf2 \
  \cf5 words"\cf2 )                                                                                          \
                  \
          \cf4 # Signal 4: Abrupt cutoff before this segment\cf2                                             \
          cutoffs_near = [\
              s \cf7 for\cf2  s \cf7 in\cf2  (audio_signals \cf7 or\cf2  [])                                                     \
              \cf7 if\cf2  s[\cf5 "signal_type"\cf2 ] == \cf5 "abrupt_cutoff"\cf2 \
              \cf7 and\cf2  raw.start_ms - \cf4 1000\cf2  < s[\cf5 "start_ms"\cf2 ] < raw.start_ms                               \
          ]                                                                                        \
          \cf7 if\cf2  cutoffs_near:\
              signal_count += \cf4 1\cf2                                                                     \
              reasons.append(\cf5 "Abrupt cutoff precedes this segment"\cf2 )\
                                                                                                   \
          \cf4 # Signal 5: VAD gap immediately before\cf2                                                    \
          \cf7 if\cf2  vad_segments:                                                                         \
              gaps_before = [                                                                      \
                  v \cf7 for\cf2  v \cf7 in\cf2  vad_segments\
                  \cf7 if\cf2  v[\cf5 "end_ms"\cf2 ] < raw.start_ms                                                    \
                  \cf7 and\cf2  raw.start_ms - v[\cf5 "end_ms"\cf2 ] > \cf4 300\cf2                                              \
                  \cf7 and\cf2  raw.start_ms - v[\cf5 "end_ms"\cf2 ] < \cf4 5000\cf2                                             \
              ]                                                                                    \
              \cf7 if\cf2  gaps_before:\
                  signal_count += \cf4 1\cf2                                                                 \
                  reasons.append(\cf5 f"VAD gap before: \{raw.start_ms - gaps_before[-\cf4 1\cf5 ]['end_ms']\}ms"\cf2 )\
                                                                                                   \
          \cf4 # Score based on converging signals\cf2                                                       \
          \cf7 if\cf2  signal_count >= \cf4 3\cf2 :                                                                    \
              score = \cf4 0.85\cf2                                                                          \
