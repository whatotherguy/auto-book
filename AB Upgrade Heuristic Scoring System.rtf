\f2\b 5. Adaptive Baseline System
\f1\b0 \
                                                                                                   \
  \cf4 # File: services/scoring/baseline.py\cf2 \
                                                                                                   \
  \cf6 @dataclass\cf2                                                                                        \
  \cf7 class AdaptiveBaseline:\cf2 \
      \cf5 """\cf2                                                                                           \
  \cf5     Rolling statistical baseline for a narrator / session / chapter.\cf2 \
  \cf5     Used to convert raw features into z-scores.\cf2                                                   \
                  \
  \cf5     Three tiers, from most specific to most general:\cf2                                              \
  \cf5       chapter \uc0\u8594  session \u8594  narrator\cf2 \
                                                                                                   \
  \cf5     A chapter baseline is computed from all segments in the current chapter.\cf2 \
  \cf5     A session baseline spans multiple chapters recorded in one session.\cf2                           \
  \cf5     A narrator baseline spans all chapters by the same narrator.\cf2                                  \
  \
  \cf5     When a chapter has < 30 segments, we blend with the session/narrator\cf2                          \
  \cf5     baseline to avoid unstable statistics.\cf2 \
  \cf5     """\cf2                                                                                           \
                  \
      tier: \cf8 str\cf2                           \cf4 # "chapter", "session", "narrator"\cf2                         \
      sample_count: \cf8 int\cf2                   \cf4 # how many segments contributed\cf2 \
      stats: \cf8 dict\cf2 [\cf8 str\cf2 , FeatureStats]     \cf4 # keyed by feature name\cf2                                    \
                                                                                                   \
      \cf7 def\cf9  z_score(self, feature_name: \cf8 str\cf9 , value: \cf8 float\cf9  | \cf7 None\cf9 ) -> \cf8 float\cf9 :\cf2                           \
          \cf7 if\cf2  value \cf7 is\cf2  \cf7 None\cf2 :                                                                        \
              \cf7 return\cf2  \cf4 0.0\cf2                                                                            \
          stats = self.stats.get(feature_name)                                                     \
          \cf7 if\cf2  stats \cf7 is\cf2  \cf7 None\cf2  \cf7 or\cf2  stats.std == \cf4 0\cf2 :\
              \cf7 return\cf2  \cf4 0.0\cf2                                                                            \
          \cf7 return\cf2  (value - stats.mean) / stats.std                                                  \
                                                                                                   \
      \cf7 def\cf9  expected_duration_ms(self, word_count: \cf8 int\cf9 ) -> \cf8 float\cf9 :\cf2                                     \
          \cf5 """Estimate expected duration from baseline speech rate."""\cf2 \
          rate_stats = self.stats.get(\cf5 "speech_rate"\cf2 )                                               \
          \cf7 if\cf2  rate_stats \cf7 is\cf2  \cf7 None\cf2  \cf7 or\cf2  rate_stats.mean <= \cf4 0\cf2 :                                           \
              \cf7 return\cf2  word_count * \cf4 300\cf2   \cf4 # fallback: ~3.3 wps\cf2                                         \
          \cf7 return\cf2  (word_count / rate_stats.mean) * \cf4 1000\cf2                                              \
                                                                                                   \
                                                                                                   \
  \cf6 @dataclass\cf2                                                                                        \
  \cf7 class FeatureStats:\cf2 \
      mean: \cf8 float\cf2 \
      std: \cf8 float\cf2                                                                                    \
      median: \cf8 float\cf2 \
      p5: \cf8 float\cf2               \cf4 # 5th percentile\cf2                                                       \
      p95: \cf8 float\cf2              \cf4 # 95th percentile\cf2 \
      count: \cf8 int\cf2 \
                                                                                                   \
                                                                                                   \
  \cf7 def\cf9  build_chapter_baseline(\cf2                                                                       \
  \cf9     segments: \cf8 list\cf9 [RawFeatureCatalog],\cf2                                                            \
  \cf9     narrator_baseline: AdaptiveBaseline | \cf7 None\cf9  = \cf7 None\cf9 ,\cf2 \
  \cf9 ) -> AdaptiveBaseline:\cf2                                                                            \
      \cf5 """\cf2 \
  \cf5     Build baseline from chapter segments.\cf2                                                         \
  \cf5     If chapter has < MIN_SEGMENTS_FOR_STABLE_BASELINE segments,\cf2                                   \
  \cf5     blend with narrator baseline.\cf2                                                                 \
  \cf5     """\cf2                                                                                           \
      MIN_SEGMENTS = \cf4 30\cf2                                                                             \
      BLEND_RATIO = \cf4 0.5\cf2   \cf4 # chapter weight when blending\cf2                                             \
                                                                                                   \
      feature_names = [                                                                            \
          \cf5 "speech_rate"\cf2 , \cf5 "f0_mean"\cf2 , \cf5 "rms_db"\cf2 , \cf5 "pause_ms"\cf2 ,                                          \
          \cf5 "duration_ms"\cf2 , \cf5 "spectral_centroid"\cf2 ,                                                      \
      ]                                                                                            \
                                                                                                   \
      stats = \{\}                                                                                   \
      \cf7 for\cf2  fname \cf7 in\cf2  feature_names:\
          values = _extract_feature_values(segments, fname)\
          chapter_stats = _compute_stats(values)\
                                                                                                   \
          \cf7 if\cf2  \cf8 len\cf2 (values) < MIN_SEGMENTS \cf7 and\cf2  narrator_baseline:                                     \
              narrator_stats = narrator_baseline.stats.get(fname)                                  \
              \cf7 if\cf2  narrator_stats:                                                                   \
                  chapter_stats = _blend_stats(chapter_stats, narrator_stats, BLEND_RATIO)\
                                                                                                   \
          stats[fname] = chapter_stats\
                                                                                                   \
      \cf7 return\cf2  AdaptiveBaseline(\
          tier=\cf5 "chapter"\cf2 ,\
          sample_count=\cf8 len\cf2 (segments),\
          stats=stats,\
      )\
                                                                                                   \
  \
  \cf7 def\cf9  detect_baseline_drift(\cf2                                                                        \
  \cf9     baseline_a: AdaptiveBaseline,\cf2 \
  \cf9     baseline_b: AdaptiveBaseline,\cf2                                                                 \
  \cf9     threshold: \cf8 float\cf9  = \cf4 1.5\cf9 ,\cf2 \
  \cf9 ) -> \cf8 list\cf9 [\cf8 str\cf9 ]:\cf2                                                                                   \
      \cf5 """\cf2          \
  \cf5     Compare two baselines (e.g., first half vs second half of chapter).\cf2 \
  \cf5     Returns list of features that drifted beyond threshold std deviations.\cf2                        \
                                                                                                   \
  \cf5     Used to detect: narrator fatigue, mic repositioning, session breaks.\cf2                          \
  \cf5     """\cf2                                                                                           \
      drifted = []                                                                                 \
      \cf7 for\cf2  fname \cf7 in\cf2  baseline_a.stats:\
          sa = baseline_a.stats.get(fname)\
          sb = baseline_b.stats.get(fname)                                                         \
          \cf7 if\cf2  sa \cf7 is\cf2  \cf7 None\cf2  \cf7 or\cf2  sb \cf7 is\cf2  \cf7 None\cf2  \cf7 or\cf2  sa.std == \cf4 0\cf2 :\
              \cf7 continue\cf2                                                                              \
          drift = \cf8 abs\cf2 (sa.mean - sb.mean) / sa.std\
          \cf7 if\cf2  drift > threshold:                                                                    \
              drifted.append(\cf5 f"\{fname\}: drift=\{drift:\cf4 .1\cf5 f\}\uc0\u963  "\cf2                                        \
                            \cf5 f"(\{sa.mean:\cf4 .2\cf5 f\} \uc0\u8594  \{sb.mean:\cf4 .2\cf5 f\})"\cf2 )                                    \
      \cf7 return\cf2  drifted                                                                               \
                                                                                                   \
  ---             \
  
\f2\b 6. Editorial Recommendation Engine (Layer 6)
\f1\b0 \
                                                                                                   \
  \cf4 # File: services/scoring/recommendations.py\cf2 \
                                                                                                   \
  \cf6 @dataclass\cf2       \
  \cf7 class EditorialRecommendation:\cf2 \
      action: \cf8 str\cf2             \cf4 # enum below\cf2                                                           \
      priority: \cf8 str\cf2           \cf4 # "critical", "high", "medium", "low", "info"\cf2                          \
      reasoning: \cf8 str\cf2          \cf4 # human-readable explanation\cf2                                           \
      confidence: \cf8 float\cf2                                                                             \
      related_issue_ids: \cf8 list\cf2 [\cf8 int\cf2 ]\
                                                                                                   \
                                                                                                   \
  \cf4 # Action enum values:\cf2 \
  \cf4 #   "review_mistake"         \'97 likely narration error, needs human check\cf2                          \
  \cf4 #   "likely_pickup"          \'97 narrator restart detected, probably cut the earlier take\cf2           \
  \cf4 #   "alt_take_available"     \'97 multiple takes exist, review and pick best\cf2                         \
  \cf4 #   "safe_auto_cut"          \'97 high confidence, safe to auto-edit\cf2                                 \
  \cf4 #   "manual_review_required" \'97 ambiguous signals, human must decide\cf2                               \
  \cf4 #   "no_action"              \'97 segment looks fine\cf2                                                 \
                                                                                                   \
                                                                                                   \
  \cf7 def\cf9  generate_recommendation(\cf2 \
  \cf9     composites: CompositeScores,\cf2                                                                  \
  \cf9     detectors: \cf8 dict\cf9 [\cf8 str\cf9 , DetectorOutput],\cf2 \
  \cf9     take_ranking: TakeRanking | \cf7 None\cf9 ,\cf2 \
  \cf9     raw: RawFeatureCatalog,\cf2                                                                       \
  \cf9 ) -> EditorialRecommendation:\cf2 \
      \cf5 """\cf2                                                                                           \
  \cf5     Decision tree for editorial recommendations.\cf2 \
  \cf5     Deterministic, ordered by priority.\cf2                                                           \
  \cf5     """\cf2                                                                                           \
                                                                                                   \
      mistake = composites.mistake_candidate                                                       \
      pickup = composites.pickup_candidate\
      splice = composites.splice_readiness\
      perf = composites.performance_quality                                                        \
  \
      \cf4 # === RULE 1: High-confidence auto-cuttable ===\cf2                                               \
      \cf7 if\cf2  (splice.score > \cf4 0.8\cf2 \
          \cf7 and\cf2  splice.confidence > \cf4 0.7\cf2                                                               \
          \cf7 and\cf2  \cf7 not\cf2  splice.ambiguity_flags):                                                         \
          \cf7 return\cf2  EditorialRecommendation(\
              action=\cf5 "safe_auto_cut"\cf2 ,                                                              \
              priority=\cf5 "low"\cf2 ,          \cf4 # low priority = auto-handled\cf2 \
              reasoning=(                                                                          \
                  \cf5 f"Splice readiness \{splice.score:\cf4 .2\cf5 f\} with confidence "\cf2 \
                  \cf5 f"\{splice.confidence:\cf4 .2\cf5 f\}. \{'; '.join(splice.reasons[:\cf4 2\cf5 ])\}"\cf2                       \
              ),                                                                                   \
              confidence=splice.confidence,\
              related_issue_ids=[],                                                                \
          )       \
                                                                                                   \
      \cf4 # === RULE 2: Alternate takes available ===\cf2 \
      \cf7 if\cf2  take_ranking \cf7 and\cf2  \cf8 len\cf2 (take_ranking.ranked_takes) >= \cf4 2\cf2 :                                     \
          top = take_ranking.ranked_takes[\cf4 0\cf2 ]\
          \cf7 return\cf2  EditorialRecommendation(                                                          \
              action=\cf5 "alt_take_available"\cf2 ,\
              priority=\cf5 "medium"\cf2 ,                                                                   \
              reasoning=(\
                  \cf5 f"\{\cf8 len\cf5 (take_ranking.ranked_takes)\} takes available. "\cf2 \
                  \cf5 f"Recommended: take \{top.rank\} (score \{top.total_score:\cf4 .2\cf5 f\}). "\cf2                   \
                  \cf5 f"\{'; '.join(take_ranking.selection_reasons)\}"\cf2                                    \
              ),                                                                                   \
              confidence=take_ranking.confidence,                                                  \
              related_issue_ids=[t.issue_id \cf7 for\cf2  t \cf7 in\cf2  take_ranking.ranked_takes \cf7 if\cf2  t.issue_id],\
          )                                                                                        \
  \
      \cf4 # === RULE 3: Strong pickup signal ===\cf2                                                        \
      \cf7 if\cf2  pickup.score > \cf4 0.6\cf2  \cf7 and\cf2  pickup.confidence > \cf4 0.5\cf2 :\
          \cf7 return\cf2  EditorialRecommendation(                                                          \
              action=\cf5 "likely_pickup"\cf2 ,\
              priority=\cf5 "high"\cf2  \cf7 if\cf2  pickup.score > \cf4 0.8\cf2  \cf7 else\cf2  \cf5 "medium"\cf2 ,                                 \
              reasoning=(                                                                          \
                  \cf5 f"Pickup candidate score \{pickup.score:\cf4 .2\cf5 f\}. "\cf2 \
                  \cf5 f"\{'; '.join(pickup.reasons[:\cf4 3\cf5 ])\}"\cf2                                                \
              ),                                                                                   \
              confidence=pickup.confidence,\
              related_issue_ids=[],                                                                \
          )       \
\
      \cf4 # === RULE 4: Strong mistake signal ===\cf2                                                       \
      \cf7 if\cf2  mistake.score > \cf4 0.5\cf2  \cf7 and\cf2  mistake.confidence > \cf4 0.5\cf2 :\
          priority = \cf5 "critical"\cf2  \cf7 if\cf2  mistake.score > \cf4 0.8\cf2  \cf7 else\cf2  \cf5 "high"\cf2                                  \
          \cf7 return\cf2  EditorialRecommendation(                                                          \
              action=\cf5 "review_mistake"\cf2 ,                                                             \
              priority=priority,                                                                   \
              reasoning=(                                                                          \
                  \cf5 f"Mistake candidate score \{mistake.score:\cf4 .2\cf5 f\}. "\cf2 \
                  \cf5 f"\{';\cf2  \cf5 '.join(mistake.reasons[:\cf4 3\cf5 ])\}"\cf2 \
              ),\
              confidence=mistake.confidence,\
              related_issue_ids=[],\
          )                                                                                        \
  \
      \cf4 # === RULE 5: Ambiguous \'97 multiple signals but no clear winner ===\cf2                            \
      triggered_count = \cf8 sum\cf2 (\cf4 1\cf2  \cf7 for\cf2  d \cf7 in\cf2  detectors.values() \cf7 if\cf2  d.triggered)\
      has_ambiguity = (                                                                            \
          mistake.ambiguity_flags\
          \cf7 or\cf2  pickup.ambiguity_flags                                                                \
          \cf7 or\cf2  splice.ambiguity_flags\
      )                                                                                            \
      \cf7 if\cf2  triggered_count >= \cf4 2\cf2  \cf7 and\cf2  has_ambiguity:\
          all_ambiguity = (\
              mistake.ambiguity_flags                                                              \
              + pickup.ambiguity_flags\
              + splice.ambiguity_flags                                                             \
          )       \
          \cf7 return\cf2  EditorialRecommendation(\
              action=\cf5 "manual_review_required"\cf2 ,\
              priority=\cf5 "medium"\cf2 ,                                                                   \
              reasoning=(                                                                          \
                  \cf5 f"\{triggered_count\} detectors triggered but signals are ambiguous. "\cf2              \
                  \cf5 f"\{'; '.join(all_ambiguity[:\cf4 3\cf5 ])\}"\cf2                                                 \
              ),                                                                                   \
              confidence=\cf4 0.4\cf2 ,\
              related_issue_ids=[],                                                                \
          )       \
\
      \cf4 # === RULE 6: Performance issue only (no text/timing error) ===\cf2                               \
      \cf7 if\cf2  perf.score < \cf4 0.5\cf2 :\
          \cf7 return\cf2  EditorialRecommendation(                                                          \
              action=\cf5 "review_mistake"\cf2 ,\
              priority=\cf5 "low"\cf2 ,                                                                      \
              reasoning=(                                                                          \
                  \cf5 f"Performance quality score \{perf.score:\cf4 .2\cf5 f\}. "\cf2 \
                  \cf5 f"\{'; '.join(perf.reasons[:\cf4 2\cf5 ])\}"\cf2                                                  \
              ),                                                                                   \
              confidence=perf.confidence,\
              related_issue_ids=[],                                                                \
          )       \
\
      \cf4 #\cf2  \cf4 ===\cf2  \cf4 DEFAULT:\cf2  \cf4 No\cf2  \cf4 action\cf2  \cf4 needed\cf2  \cf4 ===\cf2 \
      \cf7 return\cf2  EditorialRecommendation(\
          action=\cf5 "no_action"\cf2 ,                                                                      \
          priority=\cf5 "info"\cf2 ,\
          reasoning=\cf5 "No significant issues detected."\cf2 ,                                             \
          confidence=\cf4 0.9\cf2 ,                                                                          \
          related_issue_ids=[],                                                                    \
      )                                                                                            \
                                                                                                   \
                                                                                                   \
  \cf4 # === PRIORITY ORDERING FOR UI SORT ===\cf2 \
                                                                                                   \
  PRIORITY_ORDER = \{\
      \cf5 "critical"\cf2 : \cf4 0\cf2 ,\
      \cf5 "high"\cf2 : \cf4 1\cf2 ,\
      \cf5 "medium"\cf2 : \cf4 2\cf2 ,                                                                                 \
      \cf5 "low"\cf2 : \cf4 3\cf2 ,\
      \cf5 "info"\cf2 : \cf4 4\cf2 ,                                                                                   \
  \}               \
                                                                                                   \
  \cf7 def\cf9  sort_by_editorial_priority(envelopes: \cf8 list\cf9 [SegmentScoringEnvelope]) -> \cf8 list\cf9 :\cf2                  \
      \cf5 """Sort segments by editorial priority (most important first)."""\cf2                             \
      \cf7 return\cf2  \cf8 sorted\cf2 (envelopes, key=\cf7 lambda\cf2  e: (                                                     \
          PRIORITY_ORDER.get(e.recommendation.priority, \cf4 99\cf2 ),\
          -e.composite_scores.mistake_candidate.score,                                             \
          -e.composite_scores.pickup_candidate.score,\
      ))                                                                                           \
                  \
  ---                                                                                              \
  
