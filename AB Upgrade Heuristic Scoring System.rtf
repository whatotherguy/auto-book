  \
      \cf7 def\cf9  inject_pickup_pattern(self, y: np.ndarray, sr: \cf8 int\cf9 ,\cf2                                       \
  \cf9                               spoken_tokens: \cf8 list\cf9 , position: \cf8 int\cf9 ) -> \cf8 tuple\cf9 :\cf2 \
          \cf5 """\cf2                                                                                       \
  \cf5         Simulate a pickup: insert click + silence + repeat of upcoming phrase.\cf2 \
