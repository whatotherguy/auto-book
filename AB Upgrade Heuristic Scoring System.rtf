\f2\b 2. Primitive Detectors (Layer 3)
\f1\b0 \
                                  \
  Each detector is a standalone module. Each returns a \cf3 DetectorOutput\cf2 .\
                                                                                                   \
  \cf4 # File: services/scoring/detector_output.py\cf2 \
                                                                                                   \
  \cf6 @dataclass\cf2       \
  \cf7 class DetectorOutput:\cf2                                                                             \
      \cf5 """Standard output for every primitive detector."""\cf2 \
      detector_name: \cf8 str\cf2          \cf4 # e.g., "text_mismatch", "click_transient"\cf2                         \
      score: \cf8 float\cf2                \cf4 # 0.0 (no signal) to 1.0 (maximum signal)\cf2                          \
      confidence: \cf8 float\cf2           \cf4 # 0.0 (unreliable) to 1.0 (highly certain)\cf2                         \
      reasons: \cf8 list\cf2 [\cf8 str\cf2 ]         \cf4 # human-readable explanation strings\cf2                               \
      features_used: \cf8 dict\cf2         \cf4 # which raw/derived features contributed\cf2                           \
      triggered: \cf8 bool\cf2             \cf4 # score >= detector threshold\cf2                                      \
                                                                                                   \
                                                                                                   \
  \cf6 @dataclass\cf2                                                                                        \
  \cf7 class DetectorConfig:\cf2 \
      \cf5 """Threshold configuration for a single detector. Tunable by calibration."""\cf2 \
      threshold: \cf8 float\cf2            \cf4 # score must exceed this to trigger\cf2                                \
      weight: \cf8 float\cf2               \cf4 # relative weight in composite scoring\cf2 \
      enabled: \cf8 bool\cf2  = \cf7 True\cf2                                                                          \
                  \
  
\f2\b 2A. Text Detectors
\f1\b0                                                                                \
                  \
  \cf4 # File: services/scoring/detectors/text.py\cf2                                                        \
                  \
  \cf7 class TextMismatchDetector:\cf2                                                                       \
      \cf5 """Detects divergence between spoken and expected text."""\cf2 \
                                                                                                   \
      name = \cf5 "text_mismatch"\cf2 \
                                                                                                   \
      \cf7 def\cf9  evaluate(self, raw: RawFeatureCatalog, derived: DerivedFeatures) -> DetectorOutput:\cf2       \
          score = \cf4 0.0\cf2 \
          reasons = []                                                                             \
                                                                                                   \
          \cf4 # Primary signal: Levenshtein ratio (1.0 = identical, 0.0 = completely different)\cf2         \
          \cf7 if\cf2  derived.levenshtein_ratio < \cf4 1.0\cf2 :                                                      \
              score = \cf4 1.0\cf2  - derived.levenshtein_ratio                                              \
              reasons.append(\cf5 f"Text match ratio: \{derived.levenshtein_ratio:\cf4 .2\cf5 f\}"\cf2 )                 \
                                                                                                   \
          \cf4 # Boost: word count divergence\cf2                                                            \
          \cf7 if\cf2  derived.word_count_ratio < \cf4 0.5\cf2  \cf7 or\cf2  derived.word_count_ratio > \cf4 2.0\cf2 :                     \
              score = \cf8 min\cf2 (\cf4 1.0\cf2 , score + \cf4 0.2\cf2 )                                                        \
              reasons.append(\cf5 f"Word count ratio: \{derived.word_count_ratio:\cf4 .2\cf5 f\}"\cf2 )\
                                                                                                   \
          \cf4 # Suppress: very short segments (1-2 words) have noisy alignment\cf2                          \
          \cf7 if\cf2  raw.word_count_expected <= \cf4 2\cf2 :                                                         \
              score *= \cf4 0.6\cf2                                                                          \
              reasons.append(\cf5 "Short segment \'97 reduced weight"\cf2 )\
                                                                                                   \
          \cf4 # Confidence: higher when Whisper confidence is high (we trust the transcript)\cf2            \
          confidence = \cf8 min\cf2 (\cf4 1.0\cf2 , \cf4 0.4\cf2  + \cf4 0.6\cf2  * raw.whisper_word_confidence)                           \
                                                                                                   \
          \cf7 return\cf2  DetectorOutput(\
              detector_name=self.name,                                                             \
              score=\cf8 round\cf2 (score, \cf4 4\cf2 ),\
              confidence=\cf8 round\cf2 (confidence, \cf4 4\cf2 ),                                                     \
              reasons=reasons,\
              features_used=\{                                                                      \
                  \cf5 "levenshtein_ratio"\cf2 : derived.levenshtein_ratio,\
                  \cf5 "word_count_ratio"\cf2 : derived.word_count_ratio,\
                  \cf5 "whisper_confidence"\cf2 : raw.whisper_word_confidence,                               \
              \},\
              triggered=score >= \cf4 0.3\cf2 ,                                                              \
          )       \
\
                                                                                                   \
  \cf7 class RepeatedPhraseDetector:\cf2 \
      \cf5 """Detects duplicate phrase patterns \'97 repeated tokens in spoken stream."""\cf2                   \
                                                                                                   \
      name = \cf5 "repeated_phrase"\cf2 \
                                                                                                   \
      \cf7 def\cf9  evaluate(self, raw: RawFeatureCatalog, derived: DerivedFeatures) -> DetectorOutput:\cf2       \
          score = \cf4 0.0\cf2 \
          reasons = []                                                                             \
                  \
          \cf4 # Detect: spoken text contains the expected text twice\cf2                                    \
          spoken_lower = raw.spoken_text.lower()\
          expected_lower = raw.expected_text.lower()                                               \
                                                                                                   \
          \cf7 if\cf2  expected_lower \cf7 and\cf2  \cf5 f"\{expected_lower\} \{expected_lower\}"\cf2  \cf7 in\cf2  spoken_lower:              \
              score = \cf4 0.9\cf2                                                                           \
              reasons.append(\cf5 "Full phrase repeated verbatim in spoken text"\cf2 )                       \
          \cf7 elif\cf2  derived.word_count_ratio > \cf4 1.8\cf2  \cf7 and\cf2  derived.has_shared_prefix:                       \
              score = \cf4 0.7\cf2 \
              reasons.append(\cf5 f"Spoken word count \{derived.word_count_ratio:\cf4 .1\cf5 f\}x expected, with \cf2    \
  \cf5 shared prefix"\cf2 )                                                                                  \
                                                                                                   \
          \cf4 # Check for partial repeat via shared prefix + token overlap\cf2                              \
          \cf7 if\cf2  derived.shared_prefix_length >= \cf4 3\cf2  \cf7 and\cf2  derived.token_overlap_ratio > \cf4 0.7\cf2 :\
