\f2\b Question answered
\f1\b0 : "How likely is this segment a genuine narration error?"                       \
   \
  \cf4 # DEFAULT_WEIGHTS \'97 tunable by calibration\cf2                                                        \
  MISTAKE_WEIGHTS = \{                                                                              \
      \cf5 "text_mismatch"\cf2 :     \cf4 0.35\cf2 ,   \cf4 # strongest signal: text differs from manuscript\cf2 \
      \cf5 "repeated_phrase"\cf2 :   \cf4 0.20\cf2 ,   \cf4 # narrator repeated themselves\cf2                                   \
      \cf5 "skipped_text"\cf2 :      \cf4 0.20\cf2 ,   \cf4 # manuscript text not spoken\cf2                                     \
      \cf5 "abnormal_pause"\cf2 :    \cf4 0.10\cf2 ,   \cf4 # unusual timing may indicate stumble\cf2                            \
      \cf5 "rushed_delivery"\cf2 :   \cf4 0.05\cf2 ,   \cf4 # rushing suggests uncertainty\cf2                                   \
      \cf5 "clipping"\cf2 :          \cf4 0.05\cf2 ,   \cf4 # audio quality issue\cf2                                            \
      \cf5 "click_transient"\cf2 :   \cf4 0.05\cf2 ,   \cf4 # edit marker suggests known issue point\cf2                         \
  \}                                                                                                \
                                                                                                   \
  \cf7 def\cf9  compute_mistake_candidate_score(\cf2                                                              \
  \cf9     detectors: \cf8 dict\cf9 [\cf8 str\cf9 , DetectorOutput],\cf2 \
  \cf9 ) -> ScoredResult:\cf2                                                                                \
      score = \cf4 0.0\cf2  \
      components = \{\}\
      reasons = []                                                                                 \
      ambiguity = []\
                                                                                                   \
      \cf7 for\cf2  det_name, weight \cf7 in\cf2  MISTAKE_WEIGHTS.items():\
          det = detectors.get(det_name)\
          \cf7 if\cf2  det \cf7 is\cf2  \cf7 None\cf2 :                                                                          \
              \cf7 continue\cf2 \
          weighted = det.score * det.confidence * weight                                           \
          components[det_name] = \cf8 round\cf2 (weighted, \cf4 4\cf2 )\
          score += weighted                                                                        \
          \cf7 if\cf2  det.triggered:\
              reasons.extend(det.reasons)                                                          \
                  \
      \cf4 # Normalize to 0-1 range\cf2                                                                      \
      score = \cf8 min\cf2 (\cf4 1.0\cf2 , score / \cf8 sum\cf2 (MISTAKE_WEIGHTS.values()))\
                                                                                                   \
      \cf4 # Ambiguity: conflicting signals\cf2 \
      \cf7 if\cf2  (detectors.get(\cf5 "text_mismatch"\cf2 , _NULL).score > \cf4 0.5\cf2                                         \
          \cf7 and\cf2  detectors.get(\cf5 "repeated_phrase"\cf2 , _NULL).score > \cf4 0.5\cf2 ):                                \
          ambiguity.append(\cf5 "Both mismatch and repetition detected \'97 unclear if error or restart"\cf2 )\
                                                                                                   \
      \cf4 # Ambiguity: low overall alignment quality reduces trust\cf2                                      \
      \cf7 if\cf2  detectors.get(\cf5 "text_mismatch"\cf2 , _NULL).confidence < \cf4 0.5\cf2 :                                   \
          ambiguity.append(\cf5 "Low Whisper confidence \'97 transcript may be unreliable"\cf2 )                \
                  \
      confidence = _aggregate_confidence(detectors, MISTAKE_WEIGHTS)                               \
                  \
      \cf7 return\cf2  ScoredResult(                                                                         \
          score=\cf8 round\cf2 (score, \cf4 4\cf2 ),\
          confidence=\cf8 round\cf2 (confidence, \cf4 4\cf2 ),                                                         \
          components=components,\
          reasons=reasons,                                                                         \
          ambiguity_flags=ambiguity,\
