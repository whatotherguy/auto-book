\f2\b Layer
\f1\b0 \
\
  The design separates three layers that a future calibration system can consume\
   independently:\
\
  \uc0\u9484 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9488 \
  \uc0\u9474  LAYER 1: Raw Features                               \u9474 \
  \uc0\u9474   issue.audio_features  \u8594  AudioFeatures dict          \u9474 \
  \uc0\u9474   issue.prosody_features \u8594  ProsodyFeatures dict       \u9474 \
  \uc0\u9474   audio_signals.json    \u8594  per-chapter signal list     \u9474 \
  \uc0\u9474   vad_segments.json     \u8594  per-chapter VAD list        \u9474 \
  \uc0\u9474   prosody_features.json \u8594  per-token prosody           \u9474 \
  \uc0\u9474                                                       \u9474 \
  \uc0\u9474  All preserved as JSON artifacts in analysis/ dir     \u9474 \
  \uc0\u9474  Never modified by downstream steps                   \u9474 \
  \uc0\u9500 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9508 \
  \uc0\u9474  LAYER 2: Detector Outputs                            \u9474 \
  \uc0\u9474   issue.audio_signals   \u8594  AudioSignals flags          \u9474 \
  \uc0\u9474   issue.type            \u8594  classification              \u9474 \
  \uc0\u9474   issue.confidence      \u8594  per-detector confidence     \u9474 \
  \uc0\u9474   alt_take_clusters     \u8594  grouping decisions          \u9474 \
  \uc0\u9474                                                       \u9474 \
  \uc0\u9474  Derived from Layer 1 using deterministic rules       \u9474 \
  \uc0\u9474  Modular: each detector can be enabled/disabled       \u9474 \
  \uc0\u9500 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9508 \
  \uc0\u9474  LAYER 3: Composite Score (FUTURE)                    \u9474 \
  \uc0\u9474   SCORING_WEIGHTS_DEFAULT defined but not used yet    \u9474 \
  \uc0\u9474   All raw data available for simulation/calibration   \u9474 \
  \uc0\u9474   Alt-take comparison ready for A/B scoring           \u9474 \
  \uc0\u9474   Prosody contours ready for similarity metrics       \u9474 \
  \uc0\u9492 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9496 \
\
  A future calibration system can:\
  1. Load raw features from JSON artifacts\
  2. Run alternate scoring formulas without re-processing audio\
  3. Compare alt-take prosody profiles to auto-select preferred takes\
  4. Simulate threshold changes on historical data\
  5. A/B test detector configurations by replaying feature data\
\
